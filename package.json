{
  "name": "codelore-mcp",
  "version": "0.3.0",
  "description": "MCP server that maintains structured, two-perspective (internal/usage) code documentation so LLMs read summaries instead of whole codebases.",
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "documentation",
    "llm",
    "context"
  ],
  "license": "MIT",
  "author": "Paul Benchea",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PaulBenchea/codelore.git"
  },
  "bugs": {
    "url": "https://github.com/PaulBenchea/codelore/issues"
  },
  "homepage": "https://github.com/PaulBenchea/codelore#readme",
  "type": "module",
  "bin": {
    "codelore-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "minisearch": "^7.2.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
